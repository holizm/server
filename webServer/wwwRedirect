server
{
    listen 80;
    server_name www.${subdomain}${domain};
    return 301 https://${subdomain}${domain}$NginxParamsRequestUri;
}

server
{
    listen 443 http2 ssl;
    server_name www.${subdomain}${domain};

    include ${home}/${instance}/${process}/nginx/${tenant}/certificate;

    return 301 https://${subdomain}${domain}$NginxParamsRequestUri;
}
