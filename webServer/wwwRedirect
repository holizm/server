server
{
    listen 80;
    server_name www.${subdomain}${domain};
    return 301 https://${subdomain}${domain}$request_uri;
}

server
{
    listen 443 ssl;
    http2 on;
    server_name www.${subdomain}${domain};

    include ${home}/${instance}/${process}/webServer/${tenant}/certificate;

    return 301 https://${subdomain}${domain}$request_uri;
}
