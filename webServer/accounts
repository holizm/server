include ${home}/${instance}/${process}/webServer/${tenant}/httpsRedirect;

server {
    include ${home}/${instance}/${process}/webServer/${tenant}/listen;

    include ${home}/${instance}/${process}/webServer/${tenant}/certificate;

    location /js/keycloak.js {
        root /holism/server/temp;
        index keycloak.js;
    }

    location / {
        proxy_pass http://localhost:${deterministicPort};
        include ${home}/${instance}/${process}/webServer/${tenant}/proxy;
    }

    proxy_busy_buffers_size   512k;
    proxy_buffers             4 512k;
    proxy_buffer_size         256k;
}
