#!/usr/bin/env node

import { ensure } from '../scripts/ensure.js'
import {
    excludedDirs,
    getDepth,
    getDirs,
    getLines,
    isFile,
} from '../scripts/os.js'
import {
    divide,
    errorAndExit,
} from '../scripts/logger.js'
import loadParams from '../scripts/loadParams.js'
import { info } from '../scripts/logger.js'
import generateForDirectory from '../scripts/generateForDirectory.js'
import extract from '../scripts/extract.js'
import { clear } from '../scripts/terminal.js'
import generateBackupAndRestore from '../scripts/generateBackupAndRestore.js'

clear()

const findDirectories = (filter, exact) => {
    const dirs = getDirs().filter(d => !excludedDirs.includes(d))
    if (!filter) return dirs.sort()
    const f = filter.replaceAll('/', '')
    return dirs.filter(d => exact ? d === f : d.includes(f)).sort()
}

const validateDepth = params => {
    const { baseDir } = params
    if (baseDir === '/') {
        errorAndExit('Can not be executed from the root')
    }
    const depth = getDepth(baseDir)
    params.depth = depth
    if (depth !== 3) {
        errorAndExit('This command must be run from depth 3 (i.e. ~/instance)')
    }
}

const readTenants = () => {
    const tenantsFile = 'tenants'
    ensure(isFile(tenantsFile), 'Tenants file not found in the current directoryName')
    const tenants = getLines(tenantsFile).map(l => l.split(/\s+/))
    return tenants
}
const baseDir = process.cwd()
const params = loadParams(baseDir)
params.baseDir = baseDir
params.home = process.env.HOME
validateDepth(params)

const args = process.argv.slice(2)
const filterValue = args[0] || ''
const exactMatch = args.length > 1 && String(args[1]).toLowerCase() === 'only'
const directories = findDirectories(filterValue, exactMatch)
const tenants = readTenants()
for (const directoryName of directories) {
    const p = `${baseDir}/${directoryName}`
    params.directoryName = directoryName
    params.directoryPath = p
    params.depth = getDepth(params.directoryPath)
    process.chdir(p)
    divide()
    info(directoryName)
    divide()
    generateForDirectory({
        ...params,
        tenants,
    })
    process.chdir(baseDir)
}

divide()
extract(params)
generateBackupAndRestore(params)
