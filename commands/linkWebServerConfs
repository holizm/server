#!/usr/bin/env node

import path from "path"
import { runOnTerminal } from '../scripts/terminal.js'

const home = process.env.HOME
const cwd = process.cwd()

function findConfFiles() {
    try {
        const command = `find ${cwd} -type f -name "*.conf" 2>/dev/null`
        console.log(command)
        const output = runOnTerminal(command, false, true).trim()
        return output ? output.split("\n") : []
    } catch {
        return []
    }
}

function linkConfFiles(confFiles) {
    for (const file of confFiles) {
        const absolutePath = path.resolve(file)
        runOnTerminal(`ln -s -f "${absolutePath}" "${home}/nginx/conf.d"`)
    }
}

const confFiles = findConfFiles()
console.log(confFiles)
linkConfFiles(confFiles)
