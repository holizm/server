#!/usr/bin/env node

import {
    getContent,
} from '../scripts/os.js'
import {
    error,
    info,
    success,
} from '../scripts/logger.js'
import dnsProviders from '../scripts/dnsProviders.js'
import { writeFileSync } from 'fs'

const currentNameservers = getContent('/etc/resolv.conf')
    .split('\n')
    .filter(line => line.startsWith('nameserver'))
    .map(line => line.split(/\s+/)[1])
    .filter(Boolean)
info('Old nameservers:')
info(currentNameservers.join(', '))

const providerArgument = process.argv[2] || ''
const providerKeys = Object.keys(dnsProviders)
const providerCount = providerKeys.length
let newNameservers = ''
let selectedLabel = ''

if (providerArgument) {
    if (dnsProviders[providerArgument]) {
        const selected = dnsProviders[providerArgument]
        selectedLabel = selected.split('|')[0]
        newNameservers = selected.split('|')[1]
        success(`Manually set nameservers: ${selectedLabel}`)
    } else {
        error(`Invalid provider: ${providerArgument}`)
        info('Available providers:')
        providerKeys.forEach(key => {
            console.log(`- ${key}`)
        })
        process.exit(1)
    }
} else {
    let matchedIndex = -1

    for (let i = 0; i < providerKeys.length; i++) {
        const key = providerKeys[i]
        const value = dnsProviders[key]
        const ipString = value.split('|')[1]
        const firstIp = ipString.trim().split(' ')[0]

        if (currentNameservers[0] === firstIp) {
            matchedIndex = i
            break
        }
    }

    let nextIndex
    if (matchedIndex >= 0) {
        nextIndex = (matchedIndex + 1) % providerCount
    } else {
        nextIndex = 0
    }

    const nextKey = providerKeys[nextIndex]
    const nextValue = dnsProviders[nextKey]
    selectedLabel = nextValue.split('|')[0]
    newNameservers = nextValue.split('|')[1]
    success(`New nameservers: ${selectedLabel}`)
}

const nameserversContent = newNameservers.trim().split(/\s+/)
    .map(ns => `nameserver ${ns}`)
    .join('\n')

writeFileSync('/etc/resolv.conf', nameserversContent + '\n')

info('New configuration:')
info(getContent('/etc/resolv.conf'))
