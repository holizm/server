#!/usr/bin/env node

import { runOnTerminal } from '../scripts/terminal.js'
import { info } from '../scripts/logger.js'
import extract from '../scripts/extract.js'
import camelize from '../scripts/camelize.js'
import getComposePort from '../scripts/getComposePort.js'
import getReverseProxyPort from '../scripts/getReverseProxyPort.js'

const params = {}
params.depth = getDepth(process.cwd())
params.home = process.env.HOME
params = extract(params)

const {
    composeFile,
    fullProcessName,
    processPath,
} = params

const composePort = getComposePort(params)

const reverseProxyPort = getReverseProxyPort(params)

const firstConfigFile = runOnTerminal(
    `find ${processPath}/webServer -type f -name '*.config' | head -n1`,
    true
).trim()
const runningReverseProxyPort = runOnTerminal(
    `nginx -T 2>/dev/null | grep -A20 -F "$(grep -m1 server_name ${firstConfigFile} | awk '{print $2}' | tr -d ';')" | grep -oP 'proxy_pass\\s+http://localhost:\\K[0-9]+' | head -n1`,
    true
).trim()

const pid = runOnTerminal(
    `/usr/local/node/bin/pm2 pid ${fullProcessName}`,
    true
).trim()

const processPort = pid
    ? runOnTerminal(
        `lsof -Pan -p ${pid} -iTCP -sTCP:LISTEN | awk 'NR==2 {print $9}' | sed 's/.*://'`,
        true
    ).trim()
    : ''

info(`${fullProcessName}`)
info(`runningReverseProxyPort: ${runningReverseProxyPort}`)
info(`reverseProxyPort: ${reverseProxyPort}`)
info(`processPort: ${processPort}`)
info(`composePort: ${composePort}`)
