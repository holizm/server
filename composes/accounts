services:
    accounts:
        image: holism/accounts
        container_name: ${Instance}Accounts
        hostname: ${Instance}Accounts
        working_dir: /opt/keycloak
        ports:
            - 127.0.0.1:$RandomPort:8080          
        environment:
            - KC_PROXY_HEADERS=xforwarded
            - KC_BOOTSTRAP_ADMIN_USERNAME=$AccountsAdminUser
            - KC_BOOTSTRAP_ADMIN_PASSWORD=$AccountsAdminPassword
            - KC_DB=mariadb
            - KC_DB_URL_HOST=database            
            - KC_DB_URL_DATABASE=accounts
            - KC_DB_USERNAME=$AccountsMariaUser
            - KC_DB_PASSWORD=$AccountsMariaPassword
            - KC_HTTP_ENABLED=true
            - KC_HOSTNAME_STRICT=false
            - KC_DIR=/opt/keycloak/data/import
        logging:
            driver: none
        restart: always
        entrypoint: ["/bin/bash", "-c"]
        command: >
            "/opt/keycloak/bin/kc.sh build --db=mariadb &&
             /opt/keycloak/bin/kc.sh start --log-level=ROOT:ERROR --log-level=phone_otp:DEBUG --optimized"
        depends_on:
            - database
        volumes:
            - /HolismHolding/Accounts/Development.json:/opt/keycloak/data/import/development.json
            - /HolismHolding/Accounts/Themes:/opt/keycloak/themes
    database:
        image: mariadb
        container_name: ${Instance}AccountsDatabase
        ports:
            - 127.0.0.1:$${Instance}AccountsDatabaseRandomPort:3306
        environment:
            - MARIADB_ROOT_PASSWORD=$AccountsMariaRoot
            - MYSQL_DATABASE=accounts
            - MYSQL_USER=$AccountsMariaUser
            - MYSQL_PASSWORD=$AccountsMariaPassword
        volumes:
            - /${Instance}/Accounts/Databases:/var/lib/mysql
        logging:
            driver: none
        restart: always
    admin:
        image: adminer
        container_name: ${Instance}AccountsAdminer
        restart: always
        logging:
            driver: none
        ports:
            - 127.0.0.1:$${Instance}AccountsAdminerRandomPort:8080
        environment:
            - ADMINER_DEFAULT_SERVER=database
