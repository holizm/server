services:
    api:
        image: ${dockerImageName}
        container_name: ${instance}${pascalizedProcess}
        hostname: ${instance}${pascalizedProcess}
        working_dir: ${home}/${repo}/${process}
        environment:
            - org=${org}
            - repo=${repo}
            - instance=${instance}
            - process=${process}
            - apiOrg=${org}
            - apiRepo=${repo}
            - apiInstance=${instance}
            - apiProcess=${process}
        volumes:
            - ${home}/${instance}/storage:${home}/${instance}/storage
            - ${home}/${instance}/tenants:${home}/${repo}/common/tenants
            - ${home}/${instance}/common/publicSettings.json:${home}/${repo}/${githubImageNameOrProcess}/publicSettings.json
            - ${home}/${instance}/common/privateSettings.json:${home}/${repo}/${githubImageNameOrProcess}/privateSettings.json
            - ${home}/${instance}/common/connectionStrings.json:${home}/${repo}/${githubImageNameOrProcess}/connectionStrings.json
            - ${home}/${instance}/${process}/settingsOverride.json:${home}/${repo}/${githubImageNameOrProcess}/settingsOverride.json
        ports:
            - 127.0.0.1:${randomPort}:5000
        restart: always
        networks:
            - ${instance}Network
        user: "node"
        read_only: true
        init: true
        security_opt:
            - no-new-privileges:true
        cap_drop:
            - ALL
        tmpfs:
            - /tmp
            - /run
networks:
    ${instance}Network:
        name: ${instance}Network
        driver: bridge
