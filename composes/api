services:
    api:
        image: ${dockerImageName}
        container_name: ${instance}${pascalizedProcess}
        hostname: ${instance}${pascalizedProcess}
        working_dir: /${repo}/${process}
        environment:
            - org=${org}
            - repo=${repo}
            - instance=${instance}
            - process=${process}
            - apiOrg=${org}
            - apiRepo=${repo}
            - apiInstance=${instance}
            - apiProcess=${process}
            - apiProcessPath=${ProcessPath}
        volumes:
            - /${instance}/storage:/storage
            - /${instance}/tenants:/${repo}/common/tenants
            - /${instance}/common/publicSettings.json:/${repo}/${gitHubImageNameOrProcess}/publicSettings.json
            - /${instance}/common/privateSettings.json:/${repo}/${gitHubImageNameOrProcess}/privateSettings.json
            - /${instance}/common/connectionStrings.json:/${repo}/${gitHubImageNameOrProcess}/connectionStrings.json
            - /${instance}/${process}/settingsOverride.json:/${repo}/${gitHubImageNameOrProcess}/settingsOverride.json
        ports:
            - 127.0.0.1:${randomPort}:5000
        restart: always
        networks:
            - ${instance}Network
networks:
    ${instance}Network:
        name: ${instance}Network
        driver: bridge
