services:
    api:
        image: $DockerImageName
        container_name: $Instance$Process
        hostname: $Instance$Process
        working_dir: /$Repository/$Process
        environment:
            - Organization=$Organization
            - Repository=$Repository
            - Instance=$Instance
            - Process=$Process
            - ApiOrganization=${Organization}
            - ApiRepository=${Repository}
            - ApiInstance=${Instance}
            - ApiProcess=${Process}
            - ApiProcessPath=${ProcessPath}
        volumes:
            - /$Instance/Storage:/Storage
            - /$Instance/Tenants:/$Repository/Common/Tenants
            - /$Instance/Common/PublicSettings.json:/$Repository/$GitHubImageNameOrProcess/PublicSettings.json
            - /$Instance/Common/Settings.json:/$Repository/$GitHubImageNameOrProcess/Settings.json
            - /$Instance/Common/ConnectionStrings.json:/$Repository/$GitHubImageNameOrProcess/ConnectionStrings.json
            - /$Instance/$Process/SettingsOverride.json:/$Repository/$GitHubImageNameOrProcess/SettingsOverride.json
        ports:
            - 127.0.0.1:$RandomPort:5000
        restart: always
        networks:
            - ${Instance}Network
networks:
    ${Instance}Network:
        name: ${Instance}Network
        driver: bridge
