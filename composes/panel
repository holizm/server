services:
    panel:
        image: ${dockerImageName}
        container_name: ${instance}${pascalizedProcess}
        hostname: ${instance}${pascalizedProcess}
        environment:
            - org=${org}
            - repo=${repo}
            - instance=${instance}
            - process=${process}
        volumes:
            - /${instance}/common/publicSettings.json:/${repo}/${gitHubImageNameOrProcess}/Settings.json
            - /${instance}/${process}/settingsOverride.json:/${repo}/${gitHubImageNameOrProcess}/settingsOverride.json
        ports:
            - 127.0.0.1:${randomPort}:3000
        restart: always
        networks:
            - ${instance}Network
networks:
    ${instance}Network:
        name: ${instance}Network
        driver: bridge
