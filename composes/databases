services:
    database:
        image: mongo:latest
        container_name: ${Instance}Databases
        hostname: ${Instance}Databases
        volumes:
            - /${Instance}/Databases/Data:/data/db
        environment:
            - MONGO_INITDB_ROOT_USERNAME=$${Process}User
            - MONGO_INITDB_ROOT_PASSWORD=$${Process}Password
        ports:
            - $$Process:27017
        logging:
            driver: none
        networks:
            - ${Instance}Network
        # command: ["--replSet", "rs0"]
        restart: always
        healthcheck:
            test: ["CMD", "mongosh", "--eval", "db.runCommand({ ping: 1 })"]
            interval: 5s
            timeout: 5s
            retries: 5

networks:
    ${Instance}Network:
        name: ${Instance}Network
        driver: bridge
