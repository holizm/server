services:
    database:
        image: mongo:latest
        container_name: ${instance}Databases
        hostname: ${instance}Databases
        volumes:
            - ${environmentRoot}/${instance}/databases/data:/data/db
        environment:
            - MONGO_INITDB_ROOT_USERNAME=${databaseUser}
            - MONGO_INITDB_ROOT_PASSWORD=${databasePassword}
        ports:
            - ${process}:27017
        logging:
            driver: none
        networks:
            - ${instance}Network
        # command: ["--replSet", "rs0"]
        restart: always
        healthcheck:
            test: ["CMD", "mongosh", "--eval", "db.runCommand({ ping: 1 })"]
            interval: 5s
            timeout: 5s
            retries: 5

networks:
    ${instance}Network:
        name: ${instance}Network
        driver: bridge
