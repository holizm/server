services:
    site:
        image: ${dockerImageName}
        container_name: ${instance}${pascalizedProcess}
        hostname: ${instance}${pascalizedProcess}
        environment:
            - authSecret=${authSecret}
            - iamClientSecret=${iamClientSecret}
            - iamIssuer=${iamIssuer}
            - PROTOCOL_HEADER=x-forwarded-proto
            - HOST_HEADER=x-forwarded-host
            - org=${org}
            - repo=${repo}
            - instance=${instance}
            - process=${process}
        volumes:
            - ${home}/${instance}/tenants:${home}/${repo}/${githubImageNameOrProcess}/dist/tenants
            - ${home}/${instance}/common/privateSettings.json:${home}/${repo}/${githubImageNameOrProcess}/privateSettings.json
            - ${home}/${instance}/common/publicSettings.json:${home}/${repo}/${githubImageNameOrProcess}/dist/publicSettings.json
            - ${home}/${instance}/${process}/settingsOverride.json:${home}/${repo}/${githubImageNameOrProcess}/dist/settingsOverride.json
            - ${home}/${instance}/${process}:${home}/${instance}/${process}/webServerCache
            - ${home}/server/machine.json:${home}/server/machine.json
        ports:
            - 127.0.0.1:${randomPort}:3000
        restart: always
        networks:
            - ${instance}Network
networks:
    ${instance}Network:
        name: ${instance}Network
        driver: bridge
