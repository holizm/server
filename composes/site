services:
    site:
        image: ${dockerImageName}
        container_name: ${instance}${pascalizedProcess}
        hostname: ${instance}${pascalizedProcess}
        environment:
            - AUTH_SECRET=${authSecret}
            - KEYCLOAK_CLIENT_SECRET=${keycloakClientSecret}
            - KEYCLOAK_ISSUER=${keycloakIssuer}
            - PROTOCOL_HEADER=x-forwarded-proto
            - HOST_HEADER=x-forwarded-host
            - org=${org}
            - repo=${repo}
            - instance=${instance}
            - process=${process}
        volumes:
            - ${home}/${instance}/tenants:/${repo}/${gitHubImageNameOrProcess}/dist/tenants
            - ${home}/${instance}/common/privateSettings.json:/${repo}/${gitHubImageNameOrProcess}/privateSettings.json
            - ${home}/${instance}/common/publicSettings.json:/${repo}/${gitHubImageNameOrProcess}/dist/publicSettings.json
            - ${home}/${instance}/${process}/settingsOverride.json:/${repo}/${gitHubImageNameOrProcess}/dist/settingsOverride.json
            - ${home}/${instance}/${process}:/nginxCache
            - ${home}/server/machine.json:/machine.json
        ports:
            - 127.0.0.1:${randomPort}:3000
        restart: always
        networks:
            - ${instance}Network
networks:
    ${instance}Network:
        name: ${instance}Network
        driver: bridge
