#!/usr/bin/env node

import fs from 'fs'
import path from 'path'
import { execFileSync } from 'child_process'
import {
    divide,
    errorAndExit,
    info,
    success,
    warning,
} from '${environmentRoot}/server/scripts/logger.js'
import {
    createDirIfNotExists,
    getDirs,
} from '${environmentRoot}/server/scripts/os.js'

const timestampPattern = /^\d{4}-\d{2}-\d{2}_\d{2}-\d{2}-\d{2}$/

const config = {
    instance: '${instance}',
    home: '${home}',
    storageProvider: '${storageProvider}',
    databasesUser: '${databasesUser}',
    databasesPassword: '${databasesPassword}',
    azureStorage: '${azureStorage}',
    azureSas: '${azureSas}',
    awsEndpoint: '${awsEndpoint}',
    awsAccessKey: '${awsAccessKey}',
    awsSecretKey: '${awsSecretKey}',
    awsBucket: '${awsBucket}',
}

const instancePath = path.join(config.home, config.instance)
const backupDirectory = path.join(instancePath, 'backupDirectory')
const databasesContainer = config.instance + 'Databases'
const awsRemote = ':s3:' + config.awsBucket
const awsOptions = [
    '--s3-provider', 'Other',
    '--s3-endpoint', config.awsEndpoint,
    '--s3-access-key-id', config.awsAccessKey,
    '--s3-secret-access-key', config.awsSecretKey,
    '--s3-acl', 'private',
]

const run = (command, args) => execFileSync(command, args, { stdio: 'inherit' })

const capture = (command, args) => execFileSync(command, args, {
    encoding: 'utf8',
    stdio: ['ignore', 'pipe', 'inherit'],
})

const copyBackupFile = relativePath => {
    const source = path.join(instancePath, relativePath)
    const destination = path.join(backupDirectory, relativePath)
    let sourceStat

    try {
        sourceStat = fs.lstatSync(source)
    } catch {
        warning('Skipping unavailable backup file: ' + relativePath)
        return
    }

    if (!sourceStat.isFile() || sourceStat.isSymbolicLink()) {
        warning('Skipping unavailable backup file: ' + relativePath)
        return
    }

    createDirIfNotExists(path.dirname(destination))
    fs.cpSync(source, destination, { preserveTimestamps: true })
}

const prepareBackupDirectory = () => {
    info('Preparing ' + backupDirectory)
    fs.rmSync(backupDirectory, { recursive: true, force: true })

    for (const relativePath of [
        'params',
        'tenants',
        'org',
        'repo',
        'common/privateSettings.json',
        'common/publicSettings.json',
        'common/connectionStrings.json',
    ]) {
        copyBackupFile(relativePath)
    }

    const processDirectories = getDirs(instancePath).sort()

    for (const processName of processDirectories) {
        const relativePath = path.join(processName, 'settingsOverride.json')
        const settingsOverrideFile = path.join(instancePath, relativePath)
        try {
            const settingsOverrideStat = fs.lstatSync(settingsOverrideFile)
            if (settingsOverrideStat.isFile() && !settingsOverrideStat.isSymbolicLink()) {
                copyBackupFile(relativePath)
            }
        } catch { }
    }

    createDirIfNotExists(path.join(backupDirectory, 'databases', 'dumps'))
}

const dumpDatabase = database => {
    const destination = path.join(backupDirectory, 'databases', 'dumps', database + '.archive')
    const destinationFile = fs.openSync(destination, 'w')

    info('Backing up MongoDB database: ' + database)
    try {
        execFileSync('docker', [
            'exec', databasesContainer, 'mongodump',
            '--username=' + config.databasesUser,
            '--password=' + config.databasesPassword,
            '--authenticationDatabase=admin',
            '--db=' + database,
            '--archive',
            '--gzip',
            '--quiet',
        ], {
            stdio: ['ignore', destinationFile, 'inherit'],
        })
    } catch (error) {
        fs.rmSync(destination, { force: true })
        throw error
    } finally {
        fs.closeSync(destinationFile)
    }
}

const backupDatabases = databaseToBackup => {
    const databaseList = capture('docker', [
        'exec', databasesContainer, 'mongosh',
        '--quiet',
        '--username=' + config.databasesUser,
        '--password=' + config.databasesPassword,
        '--authenticationDatabase=admin',
        '--eval', 'db.adminCommand({ listDatabases: 1 }).databases.map(database => database.name).join("\\n")',
    ]).split(/\r?\n/).filter(Boolean)

    if (databaseToBackup) {
        if (!databaseList.includes(databaseToBackup)) {
            errorAndExit('Database not found: ' + databaseToBackup)
        }
        dumpDatabase(databaseToBackup)
        return
    }

    for (const database of databaseList) {
        if (database === 'admin' || database === 'local' || database === 'config') {
            continue
        }
        dumpDatabase(database)
    }
}

const validateStorageProvider = () => {
    if (config.storageProvider === 'azure' || config.storageProvider === 'aws') {
        return
    }
    errorAndExit('Unsupported storageProvider: ' + config.storageProvider)
}

const uploadBackup = timestamp => {
    info('Uploading backup/' + timestamp + ' using ' + config.storageProvider)

    if (config.storageProvider === 'azure') {
        const destination = 'https://' + config.azureStorage + '.blob.core.windows.net/backup/' + timestamp + '?' + config.azureSas
        run('azcopy', ['sync', backupDirectory, destination, '--recursive=true'])
        return
    }

    run('rclone', [
        'copy',
        backupDirectory,
        awsRemote + '/backup/' + timestamp,
        ...awsOptions,
    ])
}

const uploadCompletedMarker = timestamp => {
    const completedFile = path.join(backupDirectory, 'completed')
    fs.writeFileSync(completedFile, '')
    info('Marking backup/' + timestamp + ' as completed')

    if (config.storageProvider === 'azure') {
        const destination = 'https://' + config.azureStorage + '.blob.core.windows.net/backup/' + timestamp + '/completed?' + config.azureSas
        run('azcopy', ['copy', completedFile, destination])
        return
    }

    run('rclone', [
        'copyto',
        completedFile,
        awsRemote + '/backup/' + timestamp + '/completed',
        ...awsOptions,
    ])
}

const listBackupTimestamps = () => {
    let paths

    if (config.storageProvider === 'azure') {
        paths = capture('az', [
            'storage', 'blob', 'list',
            '--account-name=' + config.azureStorage,
            '--container-name=backup',
            '--sas-token=' + config.azureSas,
            '--query=[].name',
            '--output=tsv',
        ])
    } else {
        paths = capture('rclone', [
            'lsf',
            awsRemote + '/backup',
            '--dirs-only',
            ...awsOptions,
        ])
    }

    return [...new Set(paths
        .split(/\r?\n/)
        .filter(Boolean)
        .filter(cloudPath => cloudPath.includes('/'))
        .map(cloudPath => cloudPath.split('/')[0])
        .filter(Boolean))]
        .sort()
}

const deleteBackup = timestamp => {
    info('Deleting backup: ' + timestamp)

    if (config.storageProvider === 'azure') {
        const blobs = capture('az', [
            'storage', 'blob', 'list',
            '--account-name=' + config.azureStorage,
            '--container-name=backup',
            '--sas-token=' + config.azureSas,
            '--prefix=' + timestamp + '/',
            '--query=[].name',
            '--output=tsv',
        ])

        for (const blob of blobs.split(/\r?\n/).filter(Boolean)) {
            run('az', [
                'storage', 'blob', 'delete',
                '--account-name=' + config.azureStorage,
                '--container-name=backup',
                '--sas-token=' + config.azureSas,
                '--name=' + blob,
                '--output=none',
            ])
        }
        return
    }

    run('rclone', [
        'purge',
        awsRemote + '/backup/' + timestamp,
        ...awsOptions,
    ])
}

const pad = number => String(number).padStart(2, '0')

const formatDate = date => [
    date.getFullYear(),
    pad(date.getMonth() + 1),
    pad(date.getDate()),
].join('-')

const formatTimestamp = date => formatDate(date) + '_' + [
    pad(date.getHours()),
    pad(date.getMinutes()),
    pad(date.getSeconds()),
].join('-')

const formatIsoSeconds = date => {
    const offsetMinutes = -date.getTimezoneOffset()
    const offsetSign = offsetMinutes >= 0 ? '+' : '-'
    const absoluteOffset = Math.abs(offsetMinutes)
    const time = [pad(date.getHours()), pad(date.getMinutes()), pad(date.getSeconds())].join(':')
    const offset = offsetSign + pad(Math.floor(absoluteOffset / 60)) + ':' + pad(absoluteOffset % 60)
    return formatDate(date) + 'T' + time + offset
}

const getDateDaysAgo = (now, days) => {
    const date = new Date(now)
    date.setHours(0, 0, 0, 0)
    date.setDate(date.getDate() - days)
    return date
}

const buildRetainingDates = now => {
    const retainingDates = new Set()

    for (let days = 0; days <= 29; days++) {
        retainingDates.add(formatDate(getDateDaysAgo(now, days)))
    }

    for (let days = 30; days <= 119; days++) {
        const date = getDateDaysAgo(now, days)
        if (date.getDay() === 6) {
            retainingDates.add(formatDate(date))
        }
        retainingDates.add(formatDate(date).slice(0, 7) + '-01')
    }

    for (let months = 4; months <= 12; months++) {
        const date = new Date(now.getFullYear(), now.getMonth() - months, 1)
        retainingDates.add(formatDate(date))
    }

    return retainingDates
}

const deleteExpiredBackups = now => {
    info('Applying backup retention policy')
    const retainingDates = buildRetainingDates(now)

    for (const snapshot of listBackupTimestamps()) {
        if (!timestampPattern.test(snapshot)) {
            warning('Ignoring unrecognized backup path: ' + snapshot)
            continue
        }

        const snapshotDate = snapshot.split('_')[0]
        if (retainingDates.has(snapshotDate)) {
            info('Keeping backup: ' + snapshot)
        } else {
            deleteBackup(snapshot)
        }
    }
}

const main = args => {
    if (args.length > 1) {
        errorAndExit('Usage: backupWithNode [database]')
    }

    const databaseToBackup = args[0] || ''

    if (!databaseToBackup) {
        validateStorageProvider()
    }

    divide()
    prepareBackupDirectory()
    backupDatabases(databaseToBackup)

    if (databaseToBackup) {
        success('Local backup completed for MongoDB database: ' + databaseToBackup)
        divide()
        return
    }

    const now = new Date()
    const timestamp = formatTimestamp(now)

    divide()
    uploadBackup(timestamp)
    uploadCompletedMarker(timestamp)

    divide()
    deleteExpiredBackups(now)
    fs.appendFileSync(path.join(instancePath, 'backupLog'), formatIsoSeconds(new Date()) + '\n')
    success('Backup completed successfully')
    divide()
}

try {
    main(process.argv.slice(2))
} catch (error) {
    errorAndExit(error.message || String(error))
}
