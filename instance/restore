#!/usr/bin/env node

import fs from 'fs'
import path from 'path'
import { execFileSync } from 'child_process'
import camelize from '${environmentRoot}/server/scripts/camelize.js'
import {
    divide,
    errorAndExit,
    info,
    success,
    warning,
} from '${environmentRoot}/server/scripts/logger.js'

const usage = 'restore <snapshot-filter>,<database> [override|prefix]'
const timestampPattern = /^\d{4}-\d{2}-\d{2}_\d{2}-\d{2}-\d{2}$/
const snapshotFilterPattern = /^[0-9_-]+$/
const databasePattern = /^[A-Za-z][A-Za-z0-9_-]*$/
const prefixPattern = /^[A-Za-z][A-Za-z0-9_-]*$/

const config = {
    instance: '${instance}',
    home: '${home}',
    storageProvider: '${storageProvider}',
    databasesUser: '${databasesUser}',
    databasesPassword: '${databasesPassword}',
    azureStorage: '${azureStorage}',
    azureSas: '${azureSas}',
    awsEndpoint: '${awsEndpoint}',
    awsAccessKey: '${awsAccessKey}',
    awsSecretKey: '${awsSecretKey}',
    awsBucket: '${awsBucket}',
}

const run = (command, args, captureOutput = false) => execFileSync(command, args, {
    encoding: 'utf8',
    stdio: captureOutput ? ['ignore', 'pipe', 'inherit'] : 'inherit',
})

const fail = message => {
    throw new Error(message + '\nUsage: ' + usage)
}

const parseArguments = args => {
    if (args.length < 1 || args.length > 2) {
        fail('Invalid arguments.')
    }

    const parts = args[0].split(',')
    if (parts.length !== 2 || !parts[0] || !parts[1]) {
        fail('The first argument must contain exactly one snapshot filter and one database.')
    }

    const snapshotFilter = parts[0]
    const database = parts[1]
    const mode = args[1] || ''

    if (args.length === 2 && !args[1]) {
        fail('Restore prefix cannot be empty.')
    }
    if (!snapshotFilterPattern.test(snapshotFilter)) {
        fail('Invalid snapshot filter: ' + snapshotFilter)
    }
    if (!databasePattern.test(database)) {
        fail('Invalid database name: ' + database)
    }
    if (mode && mode !== 'override' && !prefixPattern.test(mode)) {
        fail('Invalid restore prefix: ' + mode)
    }

    return { snapshotFilter, database, mode }
}

const getAwsOptions = () => [
    '--s3-provider', 'Other',
    '--s3-endpoint', config.awsEndpoint,
    '--s3-access-key-id', config.awsAccessKey,
    '--s3-secret-access-key', config.awsSecretKey,
]

const listCloudFiles = database => {
    if (config.storageProvider === 'aws') {
        return run('rclone', [
            'lsf',
            ':s3:' + config.awsBucket + '/backup',
            '--recursive',
            '--files-only',
            '--include', '*/completed',
            '--include', '*/databases/dumps/' + database + '.archive',
            ...getAwsOptions(),
        ], true)
    }

    if (config.storageProvider === 'azure') {
        const archiveSuffix = '/databases/dumps/' + database + '.archive'
        const query = "[?ends_with(name, '/completed') || ends_with(name, '" + archiveSuffix + "')].name"
        return run('az', [
            'storage', 'blob', 'list',
            '--account-name', config.azureStorage,
            '--container-name', 'backup',
            '--sas-token', config.azureSas,
            '--query', query,
            '--output', 'tsv',
            '--only-show-errors',
        ], true)
    }

    fail('Unsupported storageProvider: ' + config.storageProvider)
}

const selectSnapshot = (cloudFiles, snapshotFilter, database) => {
    const files = new Set(cloudFiles.split(/\r?\n/).filter(Boolean))
    const snapshots = new Set()

    for (const file of files) {
        const snapshot = file.split('/')[0]
        if (timestampPattern.test(snapshot) && snapshot.includes(snapshotFilter)) {
            snapshots.add(snapshot)
        }
    }

    const archiveSuffix = '/databases/dumps/' + database + '.archive'
    return [...snapshots]
        .filter(snapshot => files.has(snapshot + '/completed'))
        .filter(snapshot => files.has(snapshot + archiveSuffix))
        .sort()
        .reverse()[0] || ''
}

const downloadArchive = (snapshot, database, archivePath) => {
    const temporaryPath = archivePath + '.download-' + process.pid
    const cloudPath = snapshot + '/databases/dumps/' + database + '.archive'

    fs.mkdirSync(path.dirname(archivePath), { recursive: true })
    fs.rmSync(temporaryPath, { force: true })

    try {
        info('Downloading database archive')
        if (config.storageProvider === 'aws') {
            run('rclone', [
                'copyto',
                ':s3:' + config.awsBucket + '/backup/' + cloudPath,
                temporaryPath,
                ...getAwsOptions(),
            ])
        } else {
            const source = 'https://' + config.azureStorage + '.blob.core.windows.net/backup/' + cloudPath + '?' + config.azureSas
            run('azcopy', ['copy', source, temporaryPath])
        }

        info('Validating database archive')
        run('gzip', ['-t', temporaryPath])
        fs.renameSync(temporaryPath, archivePath)
        success('Database archive downloaded and validated')
    } catch (error) {
        fs.rmSync(temporaryPath, { force: true })
        throw error
    }
}

const getDestinationDatabase = (database, mode) => {
    if (mode === 'override') {
        return database
    }
    return camelize((mode || 'temp') + ' ' + database)
}

const restoreDatabase = (archivePath, database, destinationDatabase) => {
    const container = config.instance + 'Databases'
    const containerArchive = '/tmp/restore-' + process.pid + '-' + database + '.archive'
    const authentication = [
        '--username', config.databasesUser,
        '--password', config.databasesPassword,
        '--authenticationDatabase', 'admin',
    ]

    try {
        info('Copying database archive to the MongoDB container')
        run('docker', ['cp', archivePath, container + ':' + containerArchive])
        const dropCommand = 'db.getSiblingDB(' + JSON.stringify(destinationDatabase) + ').dropDatabase()'
        info('Dropping destination database: ' + destinationDatabase)
        run('docker', [
            'exec', container, 'mongosh',
            '--quiet',
            ...authentication,
            '--eval', dropCommand,
        ])
        info('Restoring database: ' + database + ' -> ' + destinationDatabase)
        run('docker', [
            'exec', container, 'mongorestore',
            '--archive=' + containerArchive,
            '--gzip',
            '--nsInclude=' + database + '.*',
            '--nsFrom=' + database + '.*',
            '--nsTo=' + destinationDatabase + '.*',
            ...authentication,
            '--quiet',
        ])
        success('Database restored: ' + destinationDatabase)
    } finally {
        try {
            run('docker', ['exec', container, 'rm', '-f', containerArchive])
        } catch {
            warning('Could not remove the temporary archive from the MongoDB container')
        }
    }
}

const main = args => {
    const { snapshotFilter, database, mode } = parseArguments(args)

    divide()
    info('Finding a completed snapshot using ' + config.storageProvider)
    const cloudFiles = listCloudFiles(database)
    const snapshot = selectSnapshot(cloudFiles, snapshotFilter, database)

    if (!snapshot) {
        fail('No completed snapshot contains the requested database.')
    }
    success('Selected snapshot: ' + snapshot)

    const backupDirectory = path.join(config.home, config.instance, 'backupDirectory')
    const archivePath = path.join(backupDirectory, 'databases', 'dumps', database + '.archive')
    const destinationDatabase = getDestinationDatabase(database, mode)

    divide()
    downloadArchive(snapshot, database, archivePath)
    fs.rmSync(path.join(backupDirectory, 'completed'), { force: true })

    divide()
    restoreDatabase(archivePath, database, destinationDatabase)
    divide()
}

try {
    main(process.argv.slice(2))
} catch (error) {
    errorAndExit(error.message || String(error))
}
