#!/bin/bash

if [ -z "$1" ]; then
    echo "Specify the filters"
    exit 1
fi

DatabasesContainer=${Instance}Databases
IFS=',' read -ra params <<< "$1"

Prefix="$2"

NextMarker=""
AllBlobs=""

echo "Fetching all blob names from Azure..."
while :; do
    Response=$(az storage blob list \
        --account-name "$AzureStorage" \
        --container-name backup \
        --sas-token "$Sas" \
        --marker "$NextMarker" \
        --output json 2> >(tee /tmp/az_warnings >&2))

    Names=$(echo "$Response" | jq -r '.[].name')
    AllBlobs+="$Names"$'\n'

    NextMarker=$(grep -oP '(?<=WARNING: ).+' /tmp/az_warnings | tail -n1)

    if [ -z "$NextMarker" ]; then
        break
    fi
done

if [ -z "$AllBlobs" ]; then
    echo "No blobs found."
    exit 1
fi

FilteredBlobs="$AllBlobs"
for param in "${params[@]}"; do
    FilteredBlobs=$(echo "$FilteredBlobs" | grep "$param")
done

if [ -z "$FilteredBlobs" ]; then
    echo "No blobs matched the filters: $1"
    exit 1
fi

docker exec "$DatabasesContainer" bash -c "mkdir -p /Temp"

for Blob in $FilteredBlobs; do
    FileName=$(basename "$Blob")
    BaseName=$(echo "$FileName" | cut -d"." -f1)

    if [ -n "$Prefix" ]; then
        DatabaseName="${Prefix}${BaseName}"
        TempFileName="${Prefix}${Instance}${FileName}"
    else
        DatabaseName="$BaseName"
        TempFileName="${Instance}${FileName}"
    fi

    TempPath="/Temp/$TempFileName"

    echo "Downloading blob $Blob to $TempPath"
    az storage blob download \
        --account-name "$AzureStorage" \
        --container-name backup \
        --name "$Blob" \
        --sas-token "$Sas" \
        --file "$TempPath" 1>/dev/null

    if [ -f "$TempPath" ]; then
        docker cp "$TempPath" "$DatabasesContainer:/Temp/$TempFileName"

        docker exec "$DatabasesContainer" mongorestore \
            --archive="/Temp/$TempFileName" \
            --drop \
            --gzip \
            --nsInclude="${DatabaseName}.*" \
            --username="$DatabasesUser" \
            --password="$DatabasesPassword" \
            --authenticationDatabase=admin \
            --quiet

        echo "Restored $DatabaseName"
    else
        echo "Failed to download blob: $Blob"
    fi
done
