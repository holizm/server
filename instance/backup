#!/bin/bash

set -Eeuo pipefail

databaseToBackup=${1-}
instancePath="${home}/${instance}"
backupDirectory="$instancePath/backupDirectory"
databasesContainer="${instance}Databases"
storageProvider="${storageProvider}"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $*"
}

requireCommand() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "Required command not found: $1" >&2
        exit 1
    fi
}

dumpDatabase() {
    local database=$1
    local destination="$backupDirectory/databases/dumps/$database.archive"

    log "Backing up MongoDB database: $database"
    docker exec "$databasesContainer" mongodump \
        --username="${databasesUser}" \
        --password="${databasesPassword}" \
        --authenticationDatabase=admin \
        --db="$database" \
        --archive \
        --gzip \
        --quiet > "$destination"
}

copyBackupFile() {
    local relativePath=$1
    local source="$instancePath/$relativePath"
    local destination="$backupDirectory/$relativePath"

    if [ ! -f "$source" ] || [ -L "$source" ]; then
        log "Skipping unavailable backup file: $relativePath"
        return
    fi

    mkdir -p "$(dirname "$destination")"
    cp -p "$source" "$destination"
}

prepareBackupDirectory() {
    local processPath
    local settingsOverrideFile
    local relativePath

    log "Preparing $backupDirectory"
    rm -rf "$backupDirectory"

    copyBackupFile params
    copyBackupFile tenants
    copyBackupFile org
    copyBackupFile common/privateSettings.json
    copyBackupFile common/publicSettings.json
    copyBackupFile common/connectionStrings.json

    if [ -f "$instancePath/repo" ] && [ ! -L "$instancePath/repo" ]; then
        copyBackupFile repo
    fi

    for processPath in "$instancePath"/*/; do
        settingsOverrideFile="${processPath%/}/settingsOverride.json"
        if [ -f "$settingsOverrideFile" ] && [ ! -L "$settingsOverrideFile" ]; then
            relativePath=${settingsOverrideFile#"$instancePath/"}
            copyBackupFile "$relativePath"
        fi
    done

    mkdir -p "$backupDirectory/databases/dumps"
}

backupDatabases() {
    local databaseList
    local database

    if [ -n "$databaseToBackup" ]; then
        dumpDatabase "$databaseToBackup"
        return
    fi

    databaseList=$(docker exec "$databasesContainer" mongosh \
        --quiet \
        --username="${databasesUser}" \
        --password="${databasesPassword}" \
        --authenticationDatabase=admin \
        --eval 'db.adminCommand({ listDatabases: 1 }).databases.map(database => database.name).join("\n")')

    while IFS= read -r database; do
        if [ -z "$database" ] || [ "$database" = admin ] || [ "$database" = local ] || [ "$database" = config ]; then
            continue
        fi
        dumpDatabase "$database"
    done <<< "$databaseList"
}

configureAws() {
    awsRemote=":s3:${awsBucket}"
    awsOptions=(
        --s3-provider Other
        --s3-endpoint "${awsEndpoint}"
        --s3-access-key-id "${awsAccessKey}"
        --s3-secret-access-key "${awsSecretKey}"
        --s3-acl private
    )
}

validateStorageProvider() {
    case "$storageProvider" in
        azure)
            requireCommand az
            requireCommand azcopy
            ;;
        aws)
            requireCommand rclone
            configureAws
            ;;
        *)
            echo "Unsupported storageProvider: $storageProvider" >&2
            exit 1
            ;;
    esac
}

uploadBackup() {
    local timestamp=$1
    local destination
    log "Uploading backup/$timestamp using $storageProvider"

    case "$storageProvider" in
        azure)
            destination="https://${azureStorage}.blob.core.windows.net/backup/$timestamp?${azureSas}"
            azcopy sync "$backupDirectory" "$destination" --recursive=true
            ;;
        aws)
            rclone copy "$backupDirectory" "$awsRemote/backup/$timestamp" "${awsOptions[@]}"
            ;;
        *)
            echo "Unsupported storageProvider: $storageProvider" >&2
            exit 1
            ;;
    esac
}

uploadCompletedMarker() {
    local timestamp=$1
    local completedFile="$backupDirectory/completed"
    local destination
    : > "$completedFile"

    log "Marking backup/$timestamp as completed"
    case "$storageProvider" in
        azure)
            destination="https://${azureStorage}.blob.core.windows.net/backup/$timestamp/completed?${azureSas}"
            azcopy copy "$completedFile" "$destination"
            ;;
        aws)
            rclone copyto "$completedFile" "$awsRemote/backup/$timestamp/completed" "${awsOptions[@]}"
            ;;
    esac
}

listBackupTimestamps() {
    case "$storageProvider" in
        azure)
            az storage blob list \
                --account-name="${azureStorage}" \
                --container-name=backup \
                --sas-token="${azureSas}" \
                --query='[].name' \
                --output=tsv |
                awk -F/ 'NF > 1 { print $1 }' |
                sort -u
            ;;
        aws)
            rclone lsf "$awsRemote/backup" --dirs-only "${awsOptions[@]}" | sed 's:/$::'
            ;;
    esac
}

deleteBackup() {
    local timestamp=$1
    local blob
    log "Deleting backup: $timestamp"

    case "$storageProvider" in
        azure)
            az storage blob list \
                --account-name="${azureStorage}" \
                --container-name=backup \
                --sas-token="${azureSas}" \
                --prefix="$timestamp/" \
                --query='[].name' \
                --output=tsv |
            while IFS= read -r blob; do
                [ -n "$blob" ] || continue
                az storage blob delete \
                    --account-name="${azureStorage}" \
                    --container-name=backup \
                    --sas-token="${azureSas}" \
                    --name="$blob" \
                    --output=none
            done
            ;;
        aws)
            rclone purge "$awsRemote/backup/$timestamp" "${awsOptions[@]}"
            ;;
    esac
}

buildRetainingDates() {
    local i
    local day

    retainingDates=''

    for i in {0..29}; do
        retainingDates="$retainingDates $(date -d "-$i days" +%Y-%m-%d)"
    done

    for i in {30..119}; do
        day=$(date -d "-$i days" +%Y-%m-%d)
        if [ "$(date -d "$day" +%u)" -eq 6 ]; then
            retainingDates="$retainingDates $day"
        fi
    done

    for i in {30..119}; do
        retainingDates="$retainingDates $(date -d "-$i days" +%Y-%m-01)"
    done

    for i in {4..12}; do
        retainingDates="$retainingDates $(date -d "-$i months" +%Y-%m-01)"
    done

    retainingDates=$(printf '%s\n' $retainingDates | sort -u | tr '\n' ' ')
}

shouldKeepBackup() {
    local snapshotDate=$1
    local retainingDate

    for retainingDate in $retainingDates; do
        if [ "$snapshotDate" = "$retainingDate" ]; then
            return 0
        fi
    done
    return 1
}

deleteExpiredBackups() {
    local snapshots
    local snapshot
    local snapshotDate

    log 'Applying backup retention policy'
    buildRetainingDates
    snapshots=$(listBackupTimestamps)

    while IFS= read -r snapshot; do
        [ -n "$snapshot" ] || continue
        if ! [[ "$snapshot" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}$ ]]; then
            log "Ignoring unrecognized backup path: $snapshot"
            continue
        fi

        snapshotDate=${snapshot%%_*}
        if shouldKeepBackup "$snapshotDate"; then
            log "Keeping backup: $snapshot"
        else
            deleteBackup "$snapshot"
        fi
    done <<< "$snapshots"
}

main() {
    local timestamp

    requireCommand docker
    validateStorageProvider
    prepareBackupDirectory
    backupDatabases

    timestamp=$(date +%Y-%m-%d_%H-%M-%S)
    uploadBackup "$timestamp"
    uploadCompletedMarker "$timestamp"
    deleteExpiredBackups

    date --iso-8601=seconds >> "$instancePath/backupLog"
    log 'Backup completed successfully'
}

main "$@"
