#!/usr/bin/env bash
set -euo pipefail

. "$scripts/installer.sh"

updateApt() {
    info "Updating apt ..."
    apt-get update || error "Failed to update apt"
    success "Updated apt"
}

installCertbot() {
    apt-get install -y certbot python3-certbot-nginx || error "Failed to install certbot"
    success "Installed certbot"
}

installMicro() {
    cd /usr/local/bin && curl -fsSL https://getmic.ro | bash || error "Failed to install Micro"
    success "Installed Micro"
}

installAzCopy() {
    curl -sSL -O https://packages.microsoft.com/config/ubuntu/24.04/packages-microsoft-prod.deb
    dpkg -i packages-microsoft-prod.deb
    rm packages-microsoft-prod.deb
    apt-get update
    apt-get install -y azcopy || error "Failed to install AzCopy"
    success "Installed AzCopy"
}

installRclone() {
    curl https://rclone.org/install.sh | bash
    success "Installed Rclone"
}

installAzureCli() {
    curl -sL https://aka.ms/InstallAzureCLIDeb | bash || error "Failed to install Azure CLI"
    success "Installed Azure CLI"
}

installApache2Utils() {
    apt-get install -y apache2-utils
}

installDocker() {
    apt-get install -y apt-transport-https ca-certificates curl gnupg lsb-release
    curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /usr/share/keyrings/dockerArchiveKeyring.gpg
    echo "deb [arch=amd64 signed-by=/usr/share/keyrings/dockerArchiveKeyring.gpg] https://download.docker.com/linux/debian $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null
    apt-get update
    apt-get install -y docker-ce docker-ce-cli containerd.io || error "Failed to install Docker"
    groupadd -f docker
    usermod -aG docker "$USER"
    success "Installed Docker"
}

installDockerCompose() {
    mkdir -p /usr/local/bin
    local latestVersion
    latestVersion=$(curl -fsSL https://api.github.com/repos/docker/compose/releases/latest | grep -oP '"tag_name": "\K(.*?)(?=")')
    if [[ -z "$latestVersion" ]]; then
        error "Failed to fetch the latest Docker Compose version"
    fi
    curl -fsSL "https://github.com/docker/compose/releases/download/${latestVersion}/docker-compose-$(uname -s)-$(uname -m)" -o /usr/local/bin/docker-compose
    chmod +x /usr/local/bin/docker-compose || error "Failed to install Docker Compose"
    success "Installed Docker Compose $latestVersion"
}

installNginxFromOfficialSource() {
    info "Installing NGINX from nginx.org ..."

    apt-get install -y curl gnupg2 ca-certificates lsb-release debian-archive-keyring

    curl -fsSL https://nginx.org/keys/nginx_signing.key | gpg --dearmor \
        -o /usr/share/keyrings/nginxArchiveKeyring.gpg || error "Failed to import NGINX signing key"

    echo "deb [signed-by=/usr/share/keyrings/nginxArchiveKeyring.gpg] \
http://nginx.org/packages/debian $(lsb_release -cs) nginx" | tee /etc/apt/sources.list.d/nginx.list > /dev/null

    tee /etc/apt/preferences.d/99nginx > /dev/null <<EOF
Package: *
Pin: origin nginx.org
Pin-Priority: 900
EOF

    apt-get update
    apt-get install -y nginx || error "Failed to install NGINX"
    systemctl enable nginx
    systemctl start nginx

    success "Installed NGINX $(nginx -v 2>&1 | cut -d/ -f2)"
}

moveNginxDefaultSite() {
    if mv /etc/webServer/sites-enabled/default /etc/webServer/sites-enabled-default-backup 2>/dev/null; then
        success "Moved default Nginx site to backup"
    else
        warning "Default Nginx site was not found or already moved"
    fi
}

registerHolismCommands() {
    if grep -q "holizm" /etc/environment; then
        success "holizm commands $check_mark"
    else
        info "Registering holizm commands ..."
        chmod 644 /etc/environment
        echo 'PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$HOME/server/commands"' | tee -a /etc/environment > /dev/null
        success "Registered holizm commands"
    fi
    if grep -q "holizm" /etc/bash.bashrc; then
        success "holizm commands $check_mark"
    else
        info "Registering holizm commands ..."
        chmod 644 /etc/bash.bashrc
        echo 'PATH="${PATH}:$HOME/server/commands"' | tee -a /etc/bash.bashrc > /dev/null
        success "Registered holizm commands"
    fi
}

setTimeZone() {
    if timedatectl | grep -q "Time zone: UTC"; then
        success "Time Zone $check_mark"
        return
    fi
    info "Configuring Time Zone to UTC ..."
    timedatectl set-timezone UTC || error "Failed to set time zone"
    success "Configured Time Zone to UTC"
}

setSshPrompt() {
    truncate -s 0 /etc/skel/.bashrc
}

givePermissionsForUser() {
    usermod -aG docker $USER
}

addSbinToUserPath() {
    local file="/etc/bash.bashrc"
    local line='export PATH=$PATH:/usr/sbin'

    if ! grep -Fxq "$line" "$file"; then
        echo "$line" | tee -a "$file" > /dev/null
        echo "/usr/sbin added to PATH in $file"
    fi
}

configurePythonCore() {
    scriptsPath="/holizm/Server/Scripts/Python"
    sitePackages=$(python3 -m site --user-site)
    mkdir -p "$sitePackages"
    mkdir -p "$(dirname "$sitePackages")"
    echo "$scriptsPath" > "$sitePackages/holizm-server.pth"
    success "Configured Python core path on server"
}

addSsh() {
    local line='Defaults env_keep += "SSH_AUTH_SOCK"'
    if grep -Fxq "$line" /etc/sudoers; then
        success "SSH_AUTH_SOCK is already preserved in sudoers."
        return 0
    fi
    info "Adding SSH_AUTH_SOCK preservation to sudoers..."
    (cp /etc/sudoers /etc/sudoers.bak && \
     echo "$line" | tee -a /etc/sudoers >/dev/null && \
     vi-cf /etc/sudoers) \
    && success "Line added successfully!" \
    || (error "Error! Restoring original sudoers." && mv /etc/sudoers.bak /etc/sudoers)
}

updateApt

install curl
install git
install jq
install nethogs
install rsync
install telnet
install unzip
install zip

$setupProd/nginx installNginxFromOfficialSource
$setupProd/certbot installCertbot
$setupProd/htpasswd installApache2Utils
moveNginxDefaultSite

$setupProd/micro installMicro
$setupProd/rclone installRclone

$setupProd/az installAzureCli
$setupProd/azcopy installAzCopy

$setupProd/docker installDocker
$setupProd/docker-compose installDockerCompose

registerHolismCommands
setTimeZone
setSshPrompt
givePermissionsForUser
addSbinToUserPath
configurePythonCore
addSsh
