#!/usr/bin/env bash
set -euo pipefail

. "$scripts/installer.sh"

updateApt() {
    info "Updating apt ..."
    apt-get update || error "Failed to update apt"
    success "Updated apt"
}

setNginxDefaultSite() {
    if mv /etc/nginx/sites-enabled/default /etc/nginx/sites-enabled-default-backup 2>/dev/null; then
        success "Moved default Nginx site to backup"
    else
        success "Default Nginx site $checkMark"
    fi

    local source="/holism/server/webServer/default"
    local target="/etc/nginx/conf.d/default.conf"

    if [ -L "$target" ] && [ "$(readlink -f "$target")" = "$(readlink -f "$source")" ]; then
        success "Nginx default link already exists $checkMark"
    else
        ln -sfn "$source" "$target"
        nginx -s reload
        success "Linked Nginx default site"
    fi
}

registerHolismCommands() {
    if grep -q "holism" /etc/environment; then
        success "Holism commands $checkMark"
    else
        info "Registering holism commands ..."
        chmod 644 /etc/environment
        echo 'PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/holism/server/commands"' | tee -a /etc/environment > /dev/null
        success "Registered holism commands"
    fi
    if grep -q "holism" /etc/bash.bashrc; then
        success "Holism commands $checkMark"
    else
        info "Registering Holism commands ..."
        chmod 644 /etc/bash.bashrc
        echo 'PATH="${PATH}:/holism/server/commands"' | tee -a /etc/bash.bashrc > /dev/null
        success "Registered Holism commands"
    fi
}

setTimeZone() {
    if timedatectl | grep -q "Time zone: UTC"; then
        success "Time Zone $checkMark"
        return
    fi
    info "Configuring Time Zone to UTC ..."
    timedatectl set-timezone UTC || error "Failed to set time zone"
    success "Configured Time Zone to UTC"
}

setSshPrompt() {
    truncate -s 0 /etc/skel/.bashrc
}

addSbinToUserPath() {
    local file="/etc/bash.bashrc"
    local line='export PATH=$PATH:/usr/sbin'

    if ! grep -Fxq "$line" "$file"; then
        echo "$line" | tee -a "$file" > /dev/null
        echo "/usr/sbin added to PATH in $file"
    fi
}

preserveSshAgentInSudo() {
    local line='Defaults env_keep += "SSH_AUTH_SOCK"'
    local file='/etc/sudoers.d/ssh-auth-sock'

    if ! command -v visudo >/dev/null 2>&1; then
        warning "visudo not found. Skipping sudo SSH_AUTH_SOCK configuration."
        return 0
    fi

    if [ ! -d /etc/sudoers.d ]; then
        warning "/etc/sudoers.d not found. Skipping sudo SSH_AUTH_SOCK configuration."
        return 0
    fi

    if [ -f "$file" ] && grep -Fxq "$line" "$file" 2>/dev/null; then
        success "SSH_AUTH_SOCK already preserved in sudoers."
        return 0
    fi

    info "Adding SSH_AUTH_SOCK preservation to sudoers..."

    if echo "$line" > "$file" 2>/dev/null; then
        chmod 440 "$file" 2>/dev/null || true

        if visudo -cf "$file" >/dev/null 2>&1; then
            success "SSH_AUTH_SOCK preservation added."
        else
            warning "Invalid sudoers entry detected. Disabling it."
            rm -f "$file"
        fi
    else
        warning "Cannot write to sudoers.d. Skipping."
    fi

    return 0
}

# updateApt

install curl
install git
install jq
install nethogs
install rsync
install telnet
install unzip
install zip

$setupProd/nginx
$setupProd/certbot
$setupProd/htpasswd
setNginxDefaultSite

$setupProd/micro
$setupProd/rclone

# $setupProd/az
# $setupProd/azcopy

$setupProd/docker

# $setupProd/node

registerHolismCommands
setTimeZone
setSshPrompt
addSbinToUserPath
preserveSshAgentInSudo

source $setupProd/secureUsers.sh
source $setupProd/setPermissions.sh
$setupProd/includeUpdateTerminalTitleConfig.js

