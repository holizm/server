# Listen on a non-standard port
# Choose from private (ephemeral) range (49152–65535)
Port 53292

# Networking
AddressFamily inet

# Host keys — only strong algorithms
HostKey /etc/ssh/ssh_host_ed25519_key

# Logging
SyslogFacility AUTH
LogLevel VERBOSE

# Authentication
PermitRootLogin prohibit-password
PasswordAuthentication no
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys
PermitEmptyPasswords no
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no

# PAM (only enable if you need account/session checks)
UsePAM no

# Disable unnecessary forwarding and tunneling
AllowAgentForwarding no
AllowTcpForwarding no
X11Forwarding no
PermitTunnel no

# TTY
PermitTTY yes

# Idle session disconnect
ClientAliveInterval 300
ClientAliveCountMax 2

# Connection limits
MaxAuthTries 3
MaxSessions 5
MaxStartups 3:30:10

# Subsystem for SFTP
Subsystem sftp /usr/libexec/sftp-server

# Restrict accepted key types and algorithms (only modern)
PubkeyAcceptedKeyTypes ssh-ed25519,ecdsa-sha2-nistp256
KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

Match User debian
    AllowAgentForwarding yes
