#!/usr/bin/env bash

. "$scripts/logger.sh"

installNginxCachePurgeModule() {
    info "Installing ngx_cache_purge dynamic module..."

    apt-get install -y \
        build-essential \
        git \
        wget \
        ca-certificates \
        dpkg-dev \
        libpcre3 \
        libpcre3-dev \
        zlib1g \
        zlib1g-dev \
        libssl-dev \
        || error "Failed to install build dependencies"

    nginxVersion="$(nginx -v 2>&1 | sed -n 's|.*nginx/\(.*\)$|\1|p')"

    [ -n "$nginxVersion" ] || error "Could not detect installed NGINX version"

    info "Detected NGINX version: $nginxVersion"

    buildDir="$(mktemp -d)"

    trap 'rm -rf "$buildDir"' EXIT

    cd "$buildDir" || error "Failed to enter build directory"

    wget -q "https://nginx.org/download/nginx-$nginxVersion.tar.gz" \
        || error "Failed to download NGINX source"

    tar xf "nginx-$nginxVersion.tar.gz" \
        || error "Failed to extract NGINX source"

    git clone --depth=1 https://github.com/FRiCKLE/ngx_cache_purge.git \
        || error "Failed to clone ngx_cache_purge"

    cd "nginx-$nginxVersion" || error "NGINX source directory not found"

    nginxConfigureArgs="$(nginx -V 2>&1 | sed -n 's/^.*arguments: //p')"

    ./configure \
        $nginxConfigureArgs \
        --add-dynamic-module="$buildDir/ngx_cache_purge" \
        || error "Configure failed"

    make modules || error "Module compilation failed"

    install -d /usr/lib/nginx/modules

    install objs/ngx_http_cache_purge_module.so \
        /usr/lib/nginx/modules/ \
        || error "Failed to install module"

    install -d /etc/nginx/modules-enabled

    printf '%s\n' \
        'load_module /usr/lib/nginx/modules/ngx_http_cache_purge_module.so;' \
        >/etc/nginx/modules-enabled/50-cache-purge.conf

    nginx -t || error "NGINX configuration test failed"

    success "ngx_cache_purge module installed successfully."
}

isNginxCachePurgeModuleInstalled() {
    [ -f /usr/lib/nginx/modules/ngx_http_cache_purge_module.so ] &&
    [ -f /etc/nginx/modules-enabled/50-cache-purge.conf ]
}

if isNginxCachePurgeModuleInstalled; then
    success "ngx_cache_purge module is already installed."
else
    installNginxCachePurgeModule
fi
